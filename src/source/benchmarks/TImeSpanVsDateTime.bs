@suite()
namespace TimeSpanVsDateTime
    sub setup()
        result = 1
    end sub

    @test()
    sub roDateTime()
        date = CreateObject("roDateTime")
        result = (date.AsSeconds() * 1000) + date.GetMilliseconds()
    end sub

    @test()
    sub roTimeSpan()
        timeSpan = CreateObject("roTimeSpan") as roTimespan
        result = timeSpan.TotalMilliseconds()
    end sub
end namespace
